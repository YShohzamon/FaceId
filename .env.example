# ==============================================================
# Face Recognition Attendance System - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================

# --- Application ---
# Use 0.0.0.0 to allow phone access over Wi-Fi (http://<PC-IP>:8000)
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/face_attendance

# --- Face Recognition ---
# Similarity threshold for recognizing a face (0.0 - 1.0)
# Lower = stricter, Higher = more lenient
RECOGNITION_THRESHOLD=0.45

# GPU settings: set USE_GPU=True if you have NVIDIA GPU + CUDA installed
# GPU_ID: 0 = first GPU, -1 = CPU only
USE_GPU=False
GPU_ID=0

# --- Attendance ---
# How many seconds before the same student can be logged again
ATTENDANCE_COOLDOWN_SECONDS=30

# --- File Paths ---
FACE_IMAGES_DIR=face_data/images
EMBEDDINGS_DIR=face_data/embeddings

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
