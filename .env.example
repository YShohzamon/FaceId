# ==============================================================
# Face Recognition Attendance System - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================

# --- Application ---
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:0215@localhost:5432/face_attendance

# --- Face Recognition ---
# Cosine similarity threshold (0.0–1.0). Higher = stricter matching; lower = more lenient.
RECOGNITION_THRESHOLD=0.45

# GPU settings (requires onnxruntime-gpu + CUDA). Singletons must use settings.get_ctx_id().
USE_GPU=False
GPU_ID=0

# --- Attendance ---
# How many seconds before the same student can be logged again
ATTENDANCE_COOLDOWN_SECONDS=30

# --- File Paths ---
FACE_IMAGES_DIR=face_data/images
EMBEDDINGS_DIR=face_data/embeddings

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
