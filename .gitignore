# ==============================================================
# FaceID Attendance — Git ignore rules
# ==============================================================

# --- Virtual environment ---
.venv/
venv/
env/
ENV/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
.mypy_cache/
.ruff_cache/
.pytype/

# --- Environment & secrets (NEVER commit) ---
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# --- Logs ---
logs/*
!logs/.gitkeep
*.log

# --- Face data (images & embeddings — local only) ---
face_data/*
!face_data/.gitkeep
!face_data/images/
face_data/images/*
!face_data/images/.gitkeep
!face_data/embeddings/
face_data/embeddings/*
!face_data/embeddings/.gitkeep

# --- Database ---
*.db
*.sqlite3
*.sqlite

# --- InsightFace / ONNX models (downloaded on first run) ---
*.onnx
models/
.insightface/

# --- IDE & editors ---
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# --- OS ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Testing & coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- Build & packaging ---
dist/
build/
*.egg-info/
*.egg
pip-wheel-metadata/

# --- Cursor / local tooling ---
.cursor/

# --- Internal dev notes (not needed on GitHub) ---
PROJECT_INSTRUCTIONS.md
PROJECT_CONTINUATION.md

# --- Temporary files ---
*.tmp
*.bak
*.orig
